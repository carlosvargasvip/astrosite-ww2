---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import CTABanner from '../components/CTABanner.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);
---

<BaseLayout
  title="Free Resources — AI Tools, Guides & Technology Strategy for Founders | Carlos Vargas"
  description="Free resources for founders: AI Readiness Scorecard, AI Implementation Playbook, Fractional CTO guide, blog articles, and video content. Practical technology guidance — no hype, no paywalls."
>

  <section class="hero">
    <div class="container">
      <h1 class="hero-headline">Free Tools, Guides, and Insights to Help You Make Better Technology Decisions</h1>
      <p class="hero-sub">Everything Carlos has built to help founders navigate AI, technology strategy, and business growth — available for free.</p>
    </div>
  </section>

  <!-- AI READINESS SCORECARD -->
  <section class="section">
    <div class="container">
      <div class="featured-resource">
        <span class="resource-badge">Most Popular</span>
        <h2 class="resource-title">AI Readiness Scorecard — Find Out Exactly Where AI Fits in Your Business</h2>
        <p class="resource-description">
          The AI Readiness Scorecard is a free, 2-minute assessment that evaluates your business across five critical dimensions:
          process readiness, data readiness, technology readiness, team readiness, and strategic readiness.
        </p>
        <ul class="resource-features">
          <li>Your overall AI readiness score</li>
          <li>Breakdown across all five dimensions</li>
          <li>Specific recommendations for where to start</li>
          <li>Personalized assessment of best-fit AI tools</li>
        </ul>
        <div class="resource-meta">
          <span>Interactive assessment</span>
          <span>2 minutes</span>
          <span>Free — no credit card</span>
        </div>
        <a href="/resources/ai-readiness-scorecard/" class="btn-primary">Take the AI Readiness Scorecard</a>
      </div>
    </div>
  </section>

  <!-- AI PLAYBOOK -->
  <section class="section" style="background: rgba(255,255,255,0.02);">
    <div class="container">
      <div class="featured-resource">
        <span class="resource-badge">Free Ebook</span>
        <h2 class="resource-title">The Non-Technical Founder's AI Playbook — Implement AI in 90 Days Without Writing Code</h2>
        <p class="resource-description">
          The comprehensive guide covering everything from assessing your AI readiness to selecting tools,
          building your 90-day implementation roadmap, and avoiding the seven most common mistakes.
        </p>
        <ul class="resource-features">
          <li>AI Readiness Assessment framework</li>
          <li>Phase-by-phase 90-day implementation roadmap</li>
          <li>Tool selection guides for content, customer service, operations</li>
          <li>Real cost breakdowns for small business AI</li>
          <li>The 7 most common AI implementation mistakes</li>
        </ul>
        <div class="resource-meta">
          <span>PDF ebook (25-35 pages)</span>
          <span>Free download</span>
          <span>By Carlos E. Vargas</span>
        </div>
        <a href="/resources/ai-playbook/" class="btn-primary">Download the AI Playbook (Free)</a>
      </div>
    </div>
  </section>

  <!-- BLOG ARTICLES -->
  <section class="section">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 0.5rem;">Latest Insights on AI, Technology Strategy, and Growth</h2>
      <p class="section-subtitle" style="margin-bottom: 3rem;">Practical, no-hype articles on AI implementation, Fractional CTO insights, and technology strategy for founders.</p>
      <div class="blog-grid">
        {recentPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.slug}
          />
        ))}
      </div>
      <div style="text-align: center; margin-top: 2rem;">
        <a href="/blog/" class="btn-secondary">View All Articles</a>
      </div>
    </div>
  </section>

  <!-- FRACTIONAL CTO GUIDE -->
  <section class="section" style="background: rgba(255,255,255,0.02);">
    <div class="container">
      <div class="featured-resource compact">
        <h2 class="resource-title">The Complete Guide to Fractional CTO Services</h2>
        <p class="resource-description">
          Everything you need to know: what a Fractional CTO is, what they do day-to-day, how much they cost,
          when you need one, and how to evaluate candidates. Includes pricing data and a Fractional CTO vs. Full-Time CTO comparison.
        </p>
        <div class="resource-meta">
          <span>Long-form guide (2,800+ words)</span>
          <span>Free — no download required</span>
        </div>
        <a href="/fractional-cto/" class="btn-secondary">Read the Complete Guide</a>
      </div>
    </div>
  </section>

  <!-- TOOLS -->
  <section class="section">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 2rem;">Tools to Help You Make Better Technology Decisions</h2>
      <div class="tools-grid">
        <div class="tool-card">
          <h3>AI Readiness Scorecard</h3>
          <p>Assess your business across 5 dimensions and get personalized recommendations.</p>
          <a href="/resources/ai-readiness-scorecard/">Take the Scorecard &rarr;</a>
        </div>
        <div class="tool-card">
          <h3>Technology Stack Checklist</h3>
          <p>Compare your current stack against the recommended stack and identify gaps.</p>
          <span class="coming-soon">Coming Soon</span>
        </div>
        <div class="tool-card">
          <h3>Fractional CTO Readiness Assessment</h3>
          <p>Answer 7 questions to find out if your business has outgrown DIY technology management.</p>
          <span class="coming-soon">Coming Soon</span>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    headline="Need Personalized Guidance?"
    body="These resources are designed to help you get started. If your business needs hands-on technology leadership, the next step is a conversation."
  />

</BaseLayout>

<style>
  .hero {
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    background: linear-gradient(180deg, #0a1628 0%, #0f2440 100%);
  }

  .hero-headline {
    font-size: 2.25rem;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 1rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }

  .featured-resource {
    max-width: 800px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2.5rem;
  }

  .featured-resource.compact {
    padding: 2rem;
  }

  .resource-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: rgba(45, 212, 191, 0.15);
    color: #2dd4bf;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .resource-title {
    font-size: 1.5rem;
    color: #ffffff;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .resource-description {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .resource-features {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .resource-features li {
    padding: 0.375rem 0 0.375rem 1.25rem;
    position: relative;
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.9375rem;
  }

  .resource-features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.75rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2dd4bf;
  }

  .resource-meta {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .resource-meta span {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
    padding: 0.25rem 0.75rem;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 4px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: #2dd4bf;
    color: #0a1628;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 8px;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    background: #5eead4;
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: transparent;
    color: #2dd4bf;
    text-decoration: none;
    font-weight: 600;
    border: 2px solid rgba(45, 212, 191, 0.4);
    border-radius: 8px;
    transition: border-color 0.2s, background 0.2s;
  }

  .btn-secondary:hover {
    border-color: #2dd4bf;
    background: rgba(45, 212, 191, 0.08);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .tool-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .tool-card h3 {
    font-size: 1rem;
    color: #ffffff;
    margin-bottom: 0.75rem;
  }

  .tool-card p {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .tool-card a {
    color: #2dd4bf;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .coming-soon {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.75rem;
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .hero-headline { font-size: 1.75rem; }
    .blog-grid, .tools-grid { grid-template-columns: 1fr; }
  }
</style>
