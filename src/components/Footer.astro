      </div>

      <!-- Column 2: Services -->
      <div class="footer-col">
        <h4 class="footer-heading">Services</h4>
        <ul class="footer-links">
          <li><a href="/services/#fractional-cto">Fractional CTO</a></li>
          <li><a href="/services/#ai-implementation">AI Implementation</a></li>
          <li><a href="/services/#funnel-architecture">Funnel Architecture</a></li>
          <li><a href="/services/#troubleshooting">Tech Troubleshooting</a></li>
          <li><a href="/services/#coaching">Business Coaching</a></li>
        </ul>
      </div>

      <!-- Column 3: Resources -->
      <div class="footer-col">
        <h4 class="footer-heading">Resources</h4>
        <ul class="footer-links">
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/fractional-cto/">Fractional CTO Guide</a></li>
          <li><a href="/resources/">AI Readiness Scorecard</a></li>
          <li><a href="/resources/">AI Playbook</a></li>
          <li><a href="/faq/">FAQ</a></li>
        </ul>
      </div>

      <!-- Column 4: Connect -->
      <div class="footer-col">
        <h4 class="footer-heading">Connect</h4>
        <ul class="footer-links">
          <li><a href="/book-a-call/">Book a Strategy Call</a></li>
          <li><a href="mailto:contact@carlosvargas.com">contact@carlosvargas.com</a></li>
        </ul>
        <div class="footer-signup">
          <p class="signup-label">Get AI &amp; tech insights:</p>
          <form class="footer-form" action="/api/optin/" method="POST">
            <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
            <button type="submit">Subscribe</button>
          </form>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Carlos Vargas Consulting LLC. All rights reserved.</p>
      <div class="legal-links">
        <a href="/privacy-policy/">Privacy Policy</a>
        <a href="/terms/">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #060e1a;
    color: rgba(255, 255, 255, 0.7);
    padding: 4rem 1.5rem 2rem;
    font-family: 'Inter', sans-serif;
    border-top: 1px solid rgba(45, 212, 191, 0.1);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .footer-logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, #2dd4bf, #1e3a5f);
    border-radius: 6px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    color: #ffffff;
  }

  .footer-logo-text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: #ffffff;
  }

  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 6px;
    color: rgba(255, 255, 255, 0.6);
    background: rgba(255, 255, 255, 0.05);
    transition: color 0.2s, background 0.2s;
  }

  .social-link:hover {
    color: #2dd4bf;
    background: rgba(45, 212, 191, 0.1);
  }

  .footer-heading {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.25rem;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.625rem;
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #2dd4bf;
  }

  .footer-signup {
    margin-top: 1.5rem;
  }

  .signup-label {
    font-size: 0.8125rem;
    margin-bottom: 0.5rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .footer-form {
    display: flex;
    gap: 0.5rem;
  }

  .footer-form input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 6px;
    color: #ffffff;
    font-size: 0.8125rem;
    font-family: 'Inter', sans-serif;
  }

  .footer-form input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .footer-form button {
    padding: 0.5rem 1rem;
    background: #2dd4bf;
    color: #0a1628;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.8125rem;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .footer-form button:hover {
    background: #5eead4;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.8125rem;
  }

  .legal-links {
    display: flex;
    gap: 1.5rem;
  }

  .legal-links a {
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: color 0.2s;
  }

  .legal-links a:hover {
    color: #2dd4bf;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
