---
interface Props {
  headline?: string;
  body?: string;
  primaryCta?: string;
  primaryHref?: string;
  secondaryCta?: string;
  secondaryHref?: string;
  variant?: 'default' | 'dark';
}

const {
  headline = 'Ready to Stop Guessing and Start Building?',
  body = 'Book a 30-minute strategy call. No pitch, no pressure — just a clear look at where technology can accelerate your business.',
  primaryCta = 'Book Your Free Strategy Call',
  primaryHref = '/book-a-call/',
  secondaryCta = 'Take the AI Readiness Scorecard',
  secondaryHref = '/resources/',
  variant = 'default',
} = Astro.props;
---

<section class:list={['cta-banner', variant]}>
  <div class="cta-container">
    <h2 class="cta-headline">{headline}</h2>
    <p class="cta-body">{body}</p>
    <div class="cta-buttons">
      <a href={primaryHref} class="btn-primary">{primaryCta}</a>
      {secondaryCta && <a href={secondaryHref} class="btn-secondary">{secondaryCta}</a>}
    </div>
  </div>
</section>

<style>
  .cta-banner {
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .cta-banner.default {
    background: linear-gradient(135deg, #0f2440 0%, #1e3a5f 100%);
  }

  .cta-banner.dark {
    background: #0a1628;
    border-top: 1px solid rgba(45, 212, 191, 0.1);
    border-bottom: 1px solid rgba(45, 212, 191, 0.1);
  }

  .cta-container {
    max-width: 720px;
    margin: 0 auto;
  }

  .cta-headline {
    font-family: 'Montserrat', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .cta-body {
    font-family: 'Inter', sans-serif;
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: #2dd4bf;
    color: #0a1628;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 8px;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    background: #5eead4;
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: transparent;
    color: #2dd4bf;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    border: 2px solid rgba(45, 212, 191, 0.4);
    border-radius: 8px;
    transition: border-color 0.2s, background 0.2s;
  }

  .btn-secondary:hover {
    border-color: #2dd4bf;
    background: rgba(45, 212, 191, 0.08);
  }

  @media (max-width: 600px) {
    .cta-headline {
      font-size: 1.5rem;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
