---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import OptinPopup from '../components/OptinPopup.astro';
import { headerScripts, footerScripts } from '../config/scripts';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: object | object[];
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage = '/images/og-default.jpg',
  canonicalUrl,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://www2.carlosvargas.com';
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={ogTitle || title} />
  <meta property="og:description" content={ogDescription || description} />
  <meta property="og:image" content={new URL(ogImage, siteUrl).href} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Carlos Vargas" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle || title} />
  <meta name="twitter:description" content={ogDescription || description} />
  <meta name="twitter:image" content={new URL(ogImage, siteUrl).href} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@600;700;800&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- JSON-LD Structured Data -->
  {jsonLd && (
    Array.isArray(jsonLd)
      ? jsonLd.map((schema) => (
          <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        ))
      : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  <!-- Injected header scripts (analytics, pixels — gated by consent) -->
  {headerScripts.map((s) => (
    <Fragment set:html={s.content} />
  ))}

  <!-- Page-specific head scripts -->
  <slot name="head-scripts" />
</head>
<body>
  <Header />

  <main>
    <slot />
  </main>

  <Footer />
  <OptinPopup />
  <CookieConsent />

  <!-- Injected footer scripts -->
  {footerScripts.map((s) => (
    <Fragment set:html={s.content} />
  ))}
</body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background: #0a1628;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Montserrat', system-ui, sans-serif;
    font-weight: 700;
    line-height: 1.3;
    color: #ffffff;
  }

  a {
    color: #2dd4bf;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .section {
    padding: 5rem 1.5rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: rgba(45, 212, 191, 0.1);
    color: #2dd4bf;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.65);
    max-width: 700px;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .section {
      padding: 3rem 1.25rem;
    }

    .section-title {
      font-size: 1.5rem;
    }
  }
</style>
