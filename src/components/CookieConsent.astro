---
---

<div class="cookie-banner" id="cookie-banner" role="dialog" aria-label="Cookie consent">
  <div class="cookie-content">
    <p>We use cookies for analytics and to improve your experience. By accepting, you agree to the use of Google Analytics and Meta Pixel for traffic analysis and ad attribution.</p>
    <div class="cookie-actions">
      <button class="cookie-accept" id="cookie-accept">Accept</button>
      <button class="cookie-decline" id="cookie-decline">Decline</button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: rgba(10, 22, 40, 0.97);
    backdrop-filter: blur(10px);
    border-top: 1px solid rgba(45, 212, 191, 0.2);
    padding: 1.25rem 1.5rem;
    font-family: 'Inter', sans-serif;
  }

  .cookie-banner.visible {
    display: block;
  }

  .cookie-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .cookie-content p {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.5;
    margin: 0;
  }

  .cookie-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .cookie-accept {
    padding: 0.5rem 1.25rem;
    background: #2dd4bf;
    color: #0a1628;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.8125rem;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    transition: background 0.2s;
  }

  .cookie-accept:hover {
    background: #5eead4;
  }

  .cookie-decline {
    padding: 0.5rem 1.25rem;
    background: transparent;
    color: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 6px;
    font-weight: 500;
    font-size: 0.8125rem;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }

  .cookie-decline:hover {
    color: rgba(255, 255, 255, 0.8);
    border-color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 600px) {
    .cookie-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const declineBtn = document.getElementById('cookie-decline');

  function getCookieConsent(): string | null {
    return localStorage.getItem('cookie-consent');
  }

  function setCookieConsent(value: string): void {
    localStorage.setItem('cookie-consent', value);
  }

  function loadAnalyticsScripts(): void {
    // When consent is given, uncomment and activate the analytics scripts
    // from src/config/scripts.ts. For now this is a placeholder —
    // the actual script activation will be done by replacing the
    // commented-out script blocks with live ones in the config.
    document.dispatchEvent(new CustomEvent('cookie-consent-granted'));
  }

  // Show banner only if no consent decision has been made
  if (!getCookieConsent() && banner) {
    banner.classList.add('visible');
  }

  acceptBtn?.addEventListener('click', () => {
    setCookieConsent('accepted');
    banner?.classList.remove('visible');
    loadAnalyticsScripts();
  });

  declineBtn?.addEventListener('click', () => {
    setCookieConsent('declined');
    banner?.classList.remove('visible');
  });
</script>
